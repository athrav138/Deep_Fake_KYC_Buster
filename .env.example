# --- AI Configuration ---
# GEMINI_API_KEY: Required for Gemini AI API calls.
# IMPORTANT: This must be set in the AI Studio Secrets panel.
GEMINI_API_KEY=

# --- Application Configuration ---
# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime.
APP_URL=

# JWT_SECRET: Secret key for signing JSON Web Tokens.
# Change this to a long, random string for production.
JWT_SECRET=kyc-buster-secret-key-2026-change-me

# --- Firebase Configuration ---
# These are required for Realtime Database and Auth features.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_DATABASE_URL=
